# Copia a .env y completa los valores.

FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=storage/app/firebase/tu-service-account.json

# Interruptor global (Firestore documento platform/access, campo app_enabled)
FIRESTORE_ACCESS_COLLECTION=platform
FIRESTORE_ACCESS_DOCUMENT=access
FIRESTORE_ACCESS_FIELD=app_enabled
# Si Firestore falla o no existe el doc: true = dejar pasar, false = bloquear
PLATFORM_ACCESS_FAIL_OPEN=true
PLATFORM_ACCESS_CACHE_SECONDS=5
